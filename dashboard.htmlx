<!DOCTYPE html>
<html lang="ht">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Admin - KòmandeM 2026</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root{--brand:#FF6B35;--dark:#0A0A1A;--card:#1E293B;--border:rgba(255,255,255,0.06);--text:#E2E8F0;--text-muted:#94A3B8;--success:#22C55E;--danger:#EF4444;--warning:#F59E0B;--radius:12px;--radius-lg:20px}
        *{margin:0;padding:0;box-sizing:border-box}
        body{background:var(--dark);color:var(--text);font-family:system-ui,sans-serif;min-height:100vh;display:flex}
        
        .sidebar{width:280px;background:var(--card);border-right:1px solid var(--border);position:fixed;top:0;left:0;bottom:0;padding:1.5rem;z-index:100;overflow-y:auto;display:flex;flex-direction:column}
        .sidebar h2{color:white;font-size:1.2rem;margin-bottom:2rem;padding-bottom:1rem;border-bottom:1px solid var(--border)}
        .sidebar h2 span{color:var(--brand)}
        .sidebar a{display:flex;align-items:center;gap:0.75rem;padding:0.75rem 1rem;color:var(--text-muted);text-decoration:none;border-radius:var(--radius);font-size:0.9rem;margin-bottom:0.25rem;cursor:pointer;transition:all 0.2s}
        .sidebar a:hover,.sidebar a.active{background:rgba(255,107,53,0.1);color:var(--brand)}
        .sidebar-section{margin-top:1rem}
        .sidebar-section p{font-size:0.7rem;text-transform:uppercase;color:#64748B;padding:0.5rem 0.75rem;font-weight:700;letter-spacing:0.05em}
        .sidebar-badge{background:var(--brand);color:white;padding:0.15rem 0.5rem;border-radius:999px;font-size:0.7rem;font-weight:700;margin-left:auto}
        
        .btn-logout{width:100%;padding:0.75rem;margin-top:auto;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:var(--danger);border-radius:var(--radius);cursor:pointer;font-weight:600;font-family:inherit;font-size:0.85rem}
        .btn-logout:hover{background:rgba(239,68,68,0.2)}
        
        .main{flex:1;margin-left:280px;padding:2rem}
        .topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem}
        .topbar h1{font-size:1.5rem;font-weight:800;color:white}
        .topbar span{color:var(--text-muted);font-size:0.85rem}
        
        .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;margin-bottom:2rem}
        .stat-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.5rem;cursor:pointer;transition:all 0.3s}
        .stat-card:hover{border-color:var(--brand);transform:translateY(-2px)}
        .stat-icon{width:44px;height:44px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.25rem;margin-bottom:1rem}
        .stat-value{font-size:1.75rem;font-weight:800;color:white}
        .stat-label{font-size:0.85rem;color:var(--text-muted)}
        
        .card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-lg);margin-bottom:1.5rem;overflow:hidden}
        .card-header{padding:1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
        .card-header h3{font-size:1rem;font-weight:700;color:white}
        .card-body{padding:1.25rem}
        
        .table-wrap{overflow-x:auto}
        table{width:100%;border-collapse:collapse}
        th{padding:0.75rem;text-align:left;font-size:0.72rem;font-weight:700;color:#64748B;text-transform:uppercase;border-bottom:1px solid var(--border)}
        td{padding:0.75rem;font-size:0.85rem;border-bottom:1px solid var(--border)}
        
        .badge{display:inline-flex;padding:0.2rem 0.6rem;border-radius:999px;font-size:0.7rem;font-weight:600}
        .badge-success{background:rgba(34,197,94,0.1);color:var(--success)}
        .badge-warning{background:rgba(245,158,11,0.1);color:var(--warning)}
        .badge-brand{background:rgba(255,107,53,0.1);color:var(--brand)}
        .badge-danger{background:rgba(239,68,68,0.1);color:var(--danger)}
        
        .btn{display:inline-flex;align-items:center;gap:0.5rem;padding:0.6rem 1.2rem;border-radius:var(--radius);font-weight:600;font-size:0.85rem;cursor:pointer;border:none;font-family:inherit;transition:all 0.2s}
        .btn-primary{background:var(--brand);color:white}.btn-primary:hover{background:#E55A2B}
        .btn-outline{background:transparent;border:1px solid rgba(255,255,255,0.1);color:white}
        .btn-danger{background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:var(--danger)}
        .btn-sm{padding:0.35rem 0.75rem;font-size:0.8rem}
        
        .form-group{margin-bottom:1rem}
        .form-group label{display:block;font-weight:600;font-size:0.85rem;color:var(--text);margin-bottom:0.5rem}
        .form-input{width:100%;padding:0.75rem;background:rgba(255,255,255,0.02);border:1px solid var(--border);border-radius:var(--radius);color:white;font-size:0.9rem;outline:none;font-family:inherit;box-sizing:border-box}
        .form-input:focus{border-color:var(--brand)}
        select.form-input{cursor:pointer}
        select.form-input option{background:var(--card);color:white}
        
        .modal{position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:1000;display:none;align-items:center;justify-content:center;padding:1rem}
        .modal.show{display:flex}
        .modal-content{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-lg);width:100%;max-width:500px;max-height:85vh;overflow-y:auto}
        .modal-header{padding:1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
        .modal-header h3{color:white;font-size:1.1rem}
        .modal-close{background:none;border:none;color:#64748B;font-size:1.5rem;cursor:pointer}
        .modal-body{padding:1.25rem}
        .modal-footer{padding:1rem 1.25rem;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:0.75rem}
        
        .page{display:none}.page.active{display:block}
        
        @media(max-width:768px){.sidebar{display:none}.main{margin-left:0;padding:1rem}}
    </style>
</head>
<body>

<aside class="sidebar">
    <h2>⚡ Kòmande<span>M</span></h2>
    <div class="sidebar-section"><p>Prensipal</p>
        <a class="active" onclick="showPage('dash')"><i class="fas fa-th-large"></i>Tablo Kontwòl</a>
        <a onclick="showPage('orders')"><i class="fas fa-shopping-bag"></i>Kòmand <span class="sidebar-badge" id="pendingBadge">0</span></a>
    </div>
    <div class="sidebar-section"><p>Jesyon</p>
        <a onclick="showPage('merchants')"><i class="fas fa-store"></i>Machann</a>
        <a onclick="showPage('products')"><i class="fas fa-box"></i>Pwodui</a>
        <a onclick="showPage('drivers')"><i class="fas fa-motorcycle"></i>Livrè</a>
    </div>
    <div class="sidebar-section"><p>Finans</p>
        <a onclick="showPage('natcash')"><i class="fas fa-money-bill"></i>NatCash</a>
    </div>
    <button class="btn-logout" onclick="logout()"><i class="fas fa-sign-out-alt"></i> Dekonekte</button>
</aside>

<main class="main">

    <!-- DASHBOARD -->
    <div class="page active" id="pageDash">
        <div class="topbar"><h1>📊 Tablo Kontwòl</h1><span id="time"></span></div>
        <div class="stats">
            <div class="stat-card" onclick="showPage('orders')"><div class="stat-icon" style="background:rgba(234,179,8,0.1);color:var(--warning)"><i class="fas fa-clock"></i></div><div class="stat-value" id="s1">0</div><div class="stat-label">An Atant</div></div>
            <div class="stat-card"><div class="stat-icon" style="background:rgba(255,107,53,0.1);color:var(--brand)"><i class="fas fa-shopping-bag"></i></div><div class="stat-value" id="s2">0</div><div class="stat-label">Jodi a</div></div>
            <div class="stat-card"><div class="stat-icon" style="background:rgba(34,197,94,0.1);color:var(--success)"><i class="fas fa-dollar-sign"></i></div><div class="stat-value" id="s3">0 GDS</div><div class="stat-label">Revni</div></div>
            <div class="stat-card" onclick="showPage('merchants')"><div class="stat-icon" style="background:rgba(59,130,246,0.1);color:#3B82F6"><i class="fas fa-store"></i></div><div class="stat-value" id="s4">0</div><div class="stat-label">Machann</div></div>
        </div>
        <div class="card"><div class="card-body" style="text-align:center;padding:2rem"><p style="color:var(--success);font-size:1.2rem">✅ Sistèm Sekirize</p><p style="color:var(--text-muted)">Byenveni <strong id="wname">Admin</strong></p></div></div>
    </div>

    <!-- MERCHANTS -->
    <div class="page" id="pageMerchants">
        <div class="topbar"><h1>🏪 Jere Machann</h1><button class="btn btn-primary" onclick="addMerchant()"><i class="fas fa-plus"></i> Ajoute</button></div>
        <div class="card"><div class="table-wrap"><table><thead><tr><th>Machann</th><th>Telefòn</th><th>Balans</th><th>Aksyon</th></tr></thead><tbody id="merBody"></tbody></table></div></div>
    </div>

    <!-- PRODUCTS -->
    <div class="page" id="pageProducts">
        <div class="topbar"><h1>📦 Jere Pwodui</h1><button class="btn btn-primary" onclick="addProduct()"><i class="fas fa-plus"></i> Ajoute</button></div>
        <div class="card"><div class="table-wrap"><table><thead><tr><th>Pwodui</th><th>Kategori</th><th>Pri</th><th>Aksyon</th></tr></thead><tbody id="prodBody"></tbody></table></div></div>
    </div>

    <!-- ORDERS -->
    <div class="page" id="pageOrders">
        <div class="topbar"><h1>🛒 Jere Kòmand</h1></div>
        <div class="card"><div class="table-wrap"><table><thead><tr><th>Nimewo</th><th>Kliyan</th><th>Total</th><th>Estat</th><th>Aksyon</th></tr></thead><tbody id="ordBody"></tbody></table></div></div>
    </div>

    <!-- DRIVERS -->
    <div class="page" id="pageDrivers">
        <div class="topbar"><h1>🏍️ Jere Livrè</h1><button class="btn btn-primary" onclick="addDriver()"><i class="fas fa-plus"></i> Ajoute</button></div>
        <div class="card"><div class="table-wrap"><table><thead><tr><th>Livrè</th><th>Telefòn</th><th>Estat</th><th>Aksyon</th></tr></thead><tbody id="drvBody"></tbody></table></div></div>
    </div>

    <!-- NATCASH -->
    <div class="page" id="pageNatcash">
        <div class="topbar"><h1>💰 Retrè NatCash</h1></div>
        <div class="card" style="background:linear-gradient(135deg,rgba(255,107,53,0.1),rgba(255,107,53,0.02));text-align:center;padding:2rem;margin-bottom:1.5rem">
            <div style="font-size:3rem">🏦</div>
            <h3 style="color:white">Nimewo NatCash</h3>
            <p style="color:var(--brand);font-size:2rem;font-weight:800">32924776</p>
        </div>
        <div class="card"><div class="table-wrap"><table><thead><tr><th>Machann</th><th>Balans</th><th>Aksyon</th></tr></thead><tbody id="natBody"></tbody></table></div></div>
    </div>

</main>

<script>
// 🔔 SISTÈM TOAST NOTIFICATION BÈL
function showToast(message, type) {
    // Kreye eleman toast
    var toast = document.createElement('div');
    toast.className = 'toast-notification';
    
    // Koulè selon tip
    var colors = {
        success: { bg: '#22C55E', icon: '✅' },
        error: { bg: '#EF4444', icon: '❌' },
        warning: { bg: '#F59E0B', icon: '⚠️' },
        info: { bg: '#3B82F6', icon: 'ℹ️' },
        order: { bg: '#FF6B35', icon: '🛒' }
    };
    
    var c = colors[type] || colors.info;
    
    toast.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        background: ${c.bg};
        color: white;
        padding: 1rem 1.5rem;
        border-radius: 16px;
        font-weight: 600;
        font-size: 0.9rem;
        z-index: 9999;
        box-shadow: 0 10px 40px rgba(0,0,0,0.4);
        animation: slideInRight 0.3s ease;
        max-width: 350px;
        font-family: system-ui, sans-serif;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
    `;
    
    toast.innerHTML = c.icon + ' ' + message;
    toast.onclick = function() { toast.remove(); };
    
    document.body.appendChild(toast);
    
    // Oto-kache apre 4 segond
    setTimeout(function() {
        if (toast) {
            toast.style.animation = 'slideOutRight 0.3s ease';
            setTimeout(function() { if (toast) toast.remove(); }, 300);
        }
    }, 4000);
}

// Ajoute animasyon CSS
var toastStyle = document.createElement('style');
toastStyle.textContent = `
    @keyframes slideInRight {
        from { transform: translateX(100%); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }
    @keyframes slideOutRight {
        from { transform: translateX(0); opacity: 1; }
        to { transform: translateX(100%); opacity: 0; }
    }
`;
document.head.appendChild(toastStyle);var session=JSON.parse(localStorage.getItem('komandem-admin-session')||'null');
if(!session||session.expires<Date.now()){localStorage.removeItem('komandem-admin-session');window.location.href='login.html'}
document.getElementById('wname').textContent=session.user.non;

function fm(m){return(m||0).toLocaleString('ht-HT')+' GDS'}
function gm(){return JSON.parse(localStorage.getItem('komandem-merchants')||'[]')}
function sm(d){localStorage.setItem('komandem-merchants',JSON.stringify(d))}
function gp(){return JSON.parse(localStorage.getItem('komandem-products')||'[]')}
function sp(d){localStorage.setItem('komandem-products',JSON.stringify(d))}
function go(){return JSON.parse(localStorage.getItem('komandem-orders')||'[]')}
function so(d){localStorage.setItem('komandem-orders',JSON.stringify(d))}
function gd(){return JSON.parse(localStorage.getItem('komandem-drivers')||'[]')}
function sd(d){localStorage.setItem('komandem-drivers',JSON.stringify(d))}

function showPage(p){
    document.querySelectorAll('.page').forEach(function(el){el.classList.remove('active')});
    document.querySelectorAll('.sidebar a').forEach(function(el){el.classList.remove('active')});
    document.getElementById('page'+p.charAt(0).toUpperCase()+p.slice(1)).classList.add('active');
    event.target.classList.add('active');
    if(p==='dash')loadDash();
    if(p==='merchants')renderMerchants();
    if(p==='products')renderProducts();
    if(p==='orders')renderOrders();
    if(p==='drivers')renderDrivers();
    if(p==='natcash')renderNatCash();
}

function loadDash(){
    var o=go(),m=gm();
    var today=new Date().toDateString();
    var to=o.filter(function(x){return x.dat&&new Date(x.dat).toDateString()===today});
    document.getElementById('s1').textContent=o.filter(function(x){return x.estat==='ann_atant'}).length;
    document.getElementById('s2').textContent=to.length;
    document.getElementById('s3').textContent=fm(to.reduce(function(a,x){return a+(x.total||0)},0));
    document.getElementById('s4').textContent=m.length;
    document.getElementById('time').textContent=new Date().toLocaleString('ht-HT');
    document.getElementById('pendingBadge').textContent=o.filter(function(x){return x.estat==='ann_atant'}).length;
}
loadDash();

// MERCHANTS
function addMerchant(){
    var nom=prompt('Non biznis:');if(!nom)return;
    var tel=prompt('Telefòn:');if(!tel)return;
    var mdp=prompt('Mòdepas pou machann:','machann'+Date.now().toString(36).substr(0,4));
    var m=gm();m.push({id:'mer_'+Date.now(),non_biznis:nom,telefòn:tel,email:tel,password:mdp,estat:'aktif',balans:0,tip:'restoran',tax:10});
    sm(m);renderMerchants();loadDash();
    alert('✅ Machann ajoute!\n\nTelefòn: '+tel+'\nMòdepas: '+mdp+'\n\nKonekte sou login.html → wòl Machann');
}
function renderMerchants(){
    var m=gm();
    document.getElementById('merBody').innerHTML=m.length?m.map(function(mer){return'<tr><td><strong>'+mer.non_biznis+'</strong><br><small style="color:var(--text-muted)">'+mer.telefòn+'</small></td><td>'+mer.telefòn+'</td><td>'+fm(mer.balans)+'</td><td><button class="btn btn-outline btn-sm" onclick="deleteMerchant(\''+mer.id+'\')"><i class="fas fa-trash"></i></button></td></tr>'}).join(''):'<tr><td colspan="4" style="text-align:center;padding:2rem;color:var(--text-muted)">Pa gen machann</td></tr>';
}
function deleteMerchant(id){if(confirm('Retire?')){sm(gm().filter(function(m){return m.id!==id}));renderMerchants();}}

// PRODUCTS
function addProduct(){
    var m=gm();if(!m.length){alert('Ajoute yon machann avan!');return}
    var nom=prompt('Non pwodui:');if(!nom)return;
    var pri=parseInt(prompt('Pri (GDS):','200'));if(!pri)return;
    var cat=prompt('Kategori (dejene/dine/soupe/desè/bwason/glase):','dejene');
    var mlist=m.map(function(mer,i){return(i+1)+'. '+mer.non_biznis}).join('\n');
    var midx=parseInt(prompt('Chwazi machann:\n'+mlist,'1'))-1;
    var mer=m[midx]||m[0];
    var p=gp();p.push({id:'prod_'+Date.now(),non:nom,kategori:cat||'dejene',pri:pri,machann_id:mer.id,machann_non:mer.non_biznis,tan_preparasyon:15,disponib:true});
    sp(p);renderProducts();loadDash();alert('✅ Pwodui ajoute!');
}
function renderProducts(){
    var p=gp(),m=gm();
    document.getElementById('prodBody').innerHTML=p.length?p.map(function(pr){var mer=m.find(function(x){return x.id===pr.machann_id});return'<tr><td><strong>'+pr.non+'</strong></td><td><span class="badge badge-brand">'+(pr.kategori||'')+'</span></td><td>'+fm(pr.pri)+'</td><td><button class="btn btn-outline btn-sm" onclick="deleteProduct(\''+pr.id+'\')"><i class="fas fa-trash"></i></button></td></tr>'}).join(''):'<tr><td colspan="4" style="text-align:center;padding:2rem;color:var(--text-muted)">Pa gen pwodui</td></tr>';
}
function deleteProduct(id){if(confirm('Retire?')){sp(gp().filter(function(p){return p.id!==id}));renderProducts();}}

// ORDERS
function renderOrders(){
    var o=go();var labels={ann_atent:'An Atant',konfime:'Konfime',an_preparasyon:'An Preparasyon',an_wout:'An Wout',livre:'Livre'};
    var colors={ann_atent:'badge-warning',konfime:'badge-brand',an_preparasyon:'badge-brand',an_wout:'badge-brand',livre:'badge-success'};
    document.getElementById('ordBody').innerHTML=o.length?o.map(function(ord){return'<tr><td><strong style="color:var(--brand)">'+(ord.id||'KMD')+'</strong></td><td>'+(ord.kliyan||'-')+'</td><td>'+fm(ord.total)+'</td><td><span class="badge '+(colors[ord.estat]||'badge-warning')+'">'+(labels[ord.estat]||ord.estat)+'</span></td><td><select class="form-input" onchange="updateOrder(\''+ord.id+'\',this.value)" style="width:130px;padding:0.4rem"><option value="">Mete...</option><option value="konfime">Konfime</option><option value="an_preparasyon">An Preparasyon</option><option value="an_wout">An Wout</option><option value="livre">Livre</option></select></td></tr>'}).join(''):'<tr><td colspan="5" style="text-align:center;padding:2rem;color:var(--text-muted)">Pa gen kòmand</td></tr>';
}
function updateOrder(id,st){if(!st)return;var o=go();var i=o.findIndex(function(x){return x.id===id});if(i>=0){o[i].estat=st;so(o);renderOrders();loadDash();alert('✅ Estati mizajou!')}}

// DRIVERS
function addDriver(){
    var nom=prompt('Non livrè:');if(!nom)return;
    var tel=prompt('Telefòn:');if(!tel)return;
    var mdp=prompt('Mòdepas pou livrè:','livrè'+Date.now().toString(36).substr(0,4));
    var d=gd();d.push({id:'drv_'+Date.now(),non:nom,telefòn:tel,email:tel,password:mdp,estat:'disponib',veikil:'moto'});
    sd(d);renderDrivers();loadDash();
    alert('✅ Livrè ajoute!\n\nTelefòn: '+tel+'\nMòdepas: '+mdp+'\n\nKonekte sou login.html → wòl Livrè');
}
function renderDrivers(){
    var d=gd();
    document.getElementById('drvBody').innerHTML=d.length?d.map(function(dr){return'<tr><td><strong>'+dr.non+'</strong></td><td>'+dr.telefòn+'</td><td><span class="badge '+(dr.estat==='disponib'?'badge-success':'badge-warning')+'">'+(dr.estat||'disponib')+'</span></td><td><button class="btn btn-outline btn-sm" onclick="deleteDriver(\''+dr.id+'\')"><i class="fas fa-trash"></i></button></td></tr>'}).join(''):'<tr><td colspan="4" style="text-align:center;padding:2rem;color:var(--text-muted)">Pa gen livrè</td></tr>';
}
function deleteDriver(id){if(confirm('Retire?')){sd(gd().filter(function(d){return d.id!==id}));renderDrivers();}}

// NATCASH
function renderNatCash(){
    var m=gm();
    document.getElementById('natBody').innerHTML=m.length?m.map(function(mer){return'<tr><td><strong>'+mer.non_biznis+'</strong></td><td>'+fm(mer.balans)+'</td><td><button class="btn btn-primary btn-sm" onclick="payout(\''+mer.id+'\')" '+(mer.balans<=0?'disabled':'')+'><i class="fas fa-paper-plane"></i> Voye</button></td></tr>'}).join(''):'<tr><td colspan="3" style="text-align:center;padding:2rem;color:var(--text-muted)">Pa gen machann</td></tr>';
}
function payout(id){var m=gm();var mer=m.find(function(x){return x.id===id});if(mer&&mer.balans>0){if(confirm('Voye '+fm(mer.balans)+' sou NatCash 32924776 pou '+mer.non_biznis+'?')){mer.balans=0;sm(m);renderNatCash();alert('✅ Retrè reyisi!')}}}

function logout(){localStorage.removeItem('komandem-admin-session');window.location.href='login.html'}
</script>
</body>
</html>

